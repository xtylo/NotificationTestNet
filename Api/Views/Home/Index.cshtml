@{
    ViewData["Title"] = "Notification System";
}

<!DOCTYPE html>
<html>
<head>
    <title>Notification System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body class="bg-light">

    <div class="container py-5">

        <h1 class="mb-4">
            Notification System
        </h1>

        <div class="card mb-4">
            <div class="card-body">

                <h4 class="mb-3">
                    Send Notification
                </h4>

                <div class="mb-3">
                    <label class="form-label">
                        Category
                    </label>

                    <select id="categorySelect"
                            class="form-select">
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Message
                    </label>

                    <textarea id="messageInput"
                          class="form-control"
                              rows="4">
                </textarea>
                </div>

                <button class="btn btn-primary"
                        onclick="sendMessage()">
                    Send Notification
                </button>

                <div id="resultMessage"
                     class="mt-3">
                </div>

            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <h4 class="mb-3">
                    Notification History
                </h4>

                <table class="table table-striped">

                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Category</th>
                            <th>Channel</th>
                            <th>Status</th>
                            <th>Messages</th>
                            <th>CorrelationId</th>
                            <th>Created</th>
                        </tr>
                    </thead>

                    <tbody id="logsTableBody">
                    </tbody>

                </table>

            </div>
        </div>

    </div>

    <script>
            async function loadCategories() {

                const response =
                    await fetch('/api/v1/categories');

                const categories =
                    await response.json();

                const select =
                    document.getElementById(
                        'categorySelect');

                select.innerHTML = '';

                categories.forEach(category => {

                    const option =
                        document.createElement('option');

                    option.value = category.id;

                    option.text = category.name;

                    select.appendChild(option);
                });
            }

            async function loadLogs() {

                const response =
                    await fetch('/api/v1/notificationlogs');

                const logs =
                    await response.json();

                const tableBody =
                    document.getElementById(
                        'logsTableBody');

                tableBody.innerHTML = '';

                logs.forEach(log => {

                    tableBody.innerHTML += `
                        <tr>
                            <td>${log.userName}</td>
                            <td>${log.messageCategory}</td>
                            <td>${log.channelName}</td>
                            <td>${log.status}</td>
                            <td>${log.message}</td>
                            <td>${log.correlationId}</td>
                            <td>${new Date(log.deliveredAt).toLocaleString()}</td>
                        </tr>
                    `;
                });
            }

            async function sendMessage() {

                const categoryId =
                    parseInt(document.getElementById(
                        'categorySelect').value);

                const body =
                    document.getElementById(
                        'messageInput').value;

                const resultMessage =
                    document.getElementById(
                        'resultMessage');

                resultMessage.innerHTML = '';

                const response = await fetch(
                    '/api/v1/messages',
                    {
                        method: 'POST',

                        headers: {
                            'Content-Type': 'application/json'
                        },

                        body: JSON.stringify({
                            categoryId,
                            body
                        })
                    });

                if (response.ok) {

                    resultMessage.innerHTML =
                        `<div class="alert alert-success">
                            Notification sent successfully.
                        </div>`;

                    document.getElementById(
                        'messageInput').value = '';

                    loadLogs();
                }
                else {

                    const error =
                        await response.text();

                    resultMessage.innerHTML =
                        `<div class="alert alert-danger">
                            ${error}
                        </div>`;
                }
            }

            loadCategories();

            loadLogs();

    </script>

</body>
</html>